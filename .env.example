# Supabase project for the Catering Estimator module.
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only. Bypasses Row Level Security — never expose to the client,
# never prefix with NEXT_PUBLIC_. Required for audit-log writes and other
# privileged server operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enables AI upsell/missing-info suggestions (lib/integrations/catering).
# When unset, the estimator falls back to the rules-based suggestion checklist —
# the feature works without this key.
# AI_SUGGESTIONS_API_KEY=
