# Supabase project for the Catering Estimator module.
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only. Bypasses Row Level Security — never expose to the client,
# never prefix with NEXT_PUBLIC_. Not required by anything in the current
# feature set (every write goes through the user's own session + RLS; the
# audit log is written by SECURITY DEFINER database triggers, not app
# code) — kept here for the day something genuinely needs to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: would enable AI upsell/missing-info suggestions
# (lib/suggestions/ai.ts) if a real provider were wired up. No provider is
# implemented yet (no credentials/API docs exist for this project) --
# setting this key today does nothing. The estimator's suggestions run
# entirely on the rules-based engine (lib/suggestions/rules.ts) regardless.
# AI_SUGGESTIONS_API_KEY=
