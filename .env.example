# Restaurant Grader — environment variables
# The app runs fully in "demo mode" with none of these set: the Website,
# Local SEO, and Photo agents still do real live analysis of the URL you
# provide; Reviews/GBP/Competitors fall back to deterministic estimated data.

# Google Places API key. Enable the "Places API" in Google Cloud Console.
# Powers live reviews, Google Business Profile completeness, and competitor
# benchmarking (Reviews, GBP, Competitor agents).
GOOGLE_PLACES_API_KEY=

# Google PageSpeed Insights API key. Enable the "PageSpeed Insights API" in
# Google Cloud Console (free, no billing account required). Powers real
# Lighthouse performance/SEO/accessibility scores in the Website agent.
# If unset, falls back to GOOGLE_PLACES_API_KEY if that's set, otherwise a
# heuristic based on raw fetch timing.
GOOGLE_PAGESPEED_API_KEY=

# Anthropic API key. Powers AI-generated review sentiment summaries and the
# "Fix It" copy generator. Without it, sentiment falls back to a lexicon
# scorer and fixes fall back to a curated template library.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for sentiment/fix generation.
# Defaults to claude-haiku-4-5-20251001.
ANTHROPIC_MODEL=

# Lead capture (results page "Email me my report" form).
# Generic webhook URL — points at Zapier/Make.com/GoHighLevel/Slack/a custom
# endpoint. Each submitted lead is POSTed here as JSON. If unset, leads are
# still validated and logged server-side, but nothing is forwarded anywhere.
LEAD_WEBHOOK_URL=

# Public (client-visible) — shown as a "Book your free fix-it call" button
# after a lead submits the form. Use a scheduling link (Calendly, etc.).
NEXT_PUBLIC_BOOKING_URL=

# Public (client-visible) — fallback mailto: link for the "Book a call" CTA
# if NEXT_PUBLIC_BOOKING_URL isn't set.
NEXT_PUBLIC_CONTACT_EMAIL=
